import kotlin.Long;

CREATE TABLE BadgeLayoutItem (
    id serial AS Long PRIMARY KEY NOT NULL,
    json_data text,
    server_id bigint,
    item bigint REFERENCES Item (id) ON DELETE CASCADE,
    layout bigint REFERENCES BadgeLayout (id) ON DELETE CASCADE
);
CREATE INDEX BadgeLayoutItem_server_id_index ON BadgeLayoutItem (server_id);
CREATE INDEX BadgeLayoutItem_item_index ON BadgeLayoutItem (item);
CREATE INDEX BadgeLayoutItem_layout_index ON BadgeLayoutItem (layout);
