CREATE TABLE CheckInList_Item (
    ItemId bigint NOT NULL REFERENCES Item(id) ON DELETE CASCADE,
    CheckInListId bigint NOT NULL REFERENCES CheckInList(id) ON DELETE CASCADE,
    CONSTRAINT checkinlist_item_pkey PRIMARY KEY (ItemId, CheckInListId)
);
CREATE INDEX CheckInList_Item_ItemId_index ON CheckInList_Item (ItemId);
CREATE INDEX CheckInList_Item_CheckInListID_index ON CheckInList_Item (CheckInListId);
