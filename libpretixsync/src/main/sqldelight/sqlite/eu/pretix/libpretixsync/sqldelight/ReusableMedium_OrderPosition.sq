CREATE TABLE ReusableMedium_OrderPosition (
    ReusableMediumId INTEGER NOT NULL REFERENCES ReusableMedium (id) ON DELETE CASCADE,
    OrderPositionId INTEGER NOT NULL REFERENCES OrderPosition (id) ON DELETE CASCADE,
    PRIMARY KEY (ReusableMediumId, OrderPositionId)
);
CREATE INDEX ReusableMedium_OrderPosition_ReusableMediumId_index ON ReusableMedium_OrderPosition (ReusableMediumId);
CREATE INDEX ReusableMedium_OrderPosition_OrderPositionId_index ON ReusableMedium_OrderPosition (OrderPositionId);
